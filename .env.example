# ===== MODE APLIKASI =====
# Gunakan script switch-mode.ps1 untuk beralih mode, atau ubah manual:
#   Development: APP_ENV=development, APP_DEBUG=true
#   Production:  APP_ENV=production,  APP_DEBUG=false
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost

# ===== DATABASE =====
DB_HOST=localhost
DB_NAME=uangmu_app_db
DB_USER=root
DB_PASS=

# ===== API ROUTING =====
# Development (XAMPP lokal): API_BASE_PATH=/proj-kelola-uang/api
# Production  (hosting):     API_BASE_PATH=/api
API_BASE_PATH=/api
ALLOWED_ORIGIN=*